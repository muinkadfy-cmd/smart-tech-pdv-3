# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SMART TECH PDV - ENVIRONMENT VARIABLES
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ⚠️ IMPORTANTE:
# - Copiar este arquivo para .env.local (desenvolvimento)
# - Nunca commitar .env.local no repositório
# - Em produção, usar environment variables do Cloudflare Pages

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🗄️ SUPABASE (OBRIGATÓRIO)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# URL do projeto Supabase
# Exemplo: https://abcdefgh.supabase.co
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Anon Key (chave pública) do Supabase
# Encontrar em: Dashboard → Settings → API
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🔔 PUSH NOTIFICATIONS (OPCIONAL)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# VAPID Public Key (chave pública para Push)
# Gerar com: npx web-push generate-vapid-keys
# Esta chave pode ser pública (vai para o frontend)
VITE_VAPID_PUBLIC_KEY=BKxT7_ABC123XYZ...sua_public_key_aqui...

# ⚠️ ATENÇÃO: A VAPID Private Key NUNCA deve ir para o frontend!
# Configurar apenas no backend (Cloudflare Worker) como secret

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🏪 STORE (DESENVOLVIMENTO LOCAL)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Store ID padrão para desenvolvimento
# ⚠️ Apenas para DEV! Em produção, usar localStorage/URL
# VITE_STORE_ID=seu-store-uuid-aqui

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 📝 NOTAS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 1. GERAR VAPID KEYS:
#    npx web-push generate-vapid-keys

# 2. CONFIGURAR CLOUDFLARE WORKER (backend):
#    npx wrangler secret put VAPID_PRIVATE_KEY
#    npx wrangler secret put VAPID_EMAIL
#    npx wrangler secret put SUPABASE_SERVICE_ROLE_KEY

# 3. CLOUDFLARE PAGES (frontend):
#    Dashboard → Pages → Settings → Environment Variables
#    Adicionar: VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY, VITE_VAPID_PUBLIC_KEY

# 4. DOCUMENTAÇÃO COMPLETA:
#    Ver PUSH_NOTIFICATIONS_SETUP.md para guia passo-a-passo

# Secret para geração de tokens de reset de senha (NUNCA commitar o valor real)
VITE_RESET_HMAC_SECRET=CHANGE-ME-BEFORE-BUILD
