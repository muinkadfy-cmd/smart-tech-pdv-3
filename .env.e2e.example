# (Opcional) configs para os testes E2E (Playwright)
# Copie para .env.local se quiser sobrescrever no seu PC.

# Store a ser usado pelos testes
E2E_STORE_ID=7371cfdc-7df5-4543-95b0-882da2de6ab9

# Se quiser apontar para outro host/porta
#E2E_HOST=127.0.0.1
#E2E_PORT=4173
#E2E_BASE_URL=http://127.0.0.1:4173

# (Opcional) sobrescrever identidade do superadmin usada no bootstrap da sessão
#E2E_SUPERADMIN_ID=dbba6a2a-9169-46a0-9c0e-dfcd4efea13e
#E2E_SUPERADMIN_EMAIL=muinkadfy@gmail.com